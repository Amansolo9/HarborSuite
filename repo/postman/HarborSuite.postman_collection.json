    {
      "name": "12 - Confirm Quote (sets reconfirm token)",
      "event": [
        {
          "listen": "prerequest",
          "script": {
            "type": "text/javascript",
            "exec": [
              "const now = new Date();",
              "const end = new Date(now.getTime() + 45 * 60 * 1000);",
              "pm.collectionVariables.set('delivery_window_start', now.toISOString());",
              "pm.collectionVariables.set('delivery_window_end', end.toISOString());"
            ]
          }
        },
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Confirm quote OK', function () { pm.response.to.have.status(200); });",
              "const r = pm.response.json();",
              "pm.collectionVariables.set('reconfirm_token', r.reconfirm_token || '');",
              "pm.collectionVariables.set('quote_hash', r.quote_hash || '');"
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          { "key": "Authorization", "value": "Bearer {{token_guest}}" },
          { "key": "Content-Type", "value": "application/json" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"folio_id\": \"{{folio_id}}\",\n  \"items\": [\n    {\n      \"sku\": \"food_club_sandwich\",\n      \"name\": \"Club sandwich\",\n      \"quantity\": 1,\n      \"unit_price\": \"14.00\",\n      \"size\": \"regular\",\n      \"specs\": {\"sauce\": \"light\"},\n      \"delivery_slot_label\": \"late-night\"\n    }\n  ],\n  \"payment_method\": \"cash\",\n  \"packaging_fee\": \"1.00\",\n  \"service_fee\": \"1.00\",\n  \"tax_rate\": \"0.10\",\n  \"delivery_window_start\": \"{{delivery_window_start}}\",\n  \"delivery_window_end\": \"{{delivery_window_end}}\"\n}"
        },
        "url": "{{baseUrl}}/api/v1/orders/confirm-quote"
